# ===========================================
# ROOTED WITH LIZA - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# PAYMENT PROVIDER CONFIGURATION
# ===========================================
# Set PAYMENT_PROVIDER to 'paystack' (currently active) or 'stripe' (for future subscriptions)
PAYMENT_PROVIDER=paystack
PAYMENTS_ENABLED=true

# --- Paystack (Active - South Africa) ---
# Get keys from: https://paystack.com (Dashboard -> Settings -> API Keys)
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe (For Future Subscription Use) ---
# Get keys from: https://stripe.com (Dashboard -> Developers -> API Keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (create in Stripe Dashboard -> Products)
STRIPE_PRICE_CORE=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PLUS=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_FAMILY=price_xxxxxxxxxxxxxxxxxxxx

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Get from: https://supabase.com (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# APPLICATION CONFIG
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# EMAIL CONFIGURATION (Resend)
# ===========================================
# Get API key from: https://resend.com (Dashboard -> API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address where you want to receive application notifications
ADMIN_EMAIL=hello@rootedwithliza.co.za

# ===========================================
# PAYSTACK SETUP GUIDE
# ===========================================
# 1. Create account at https://paystack.com
# 2. Verify your account (required for live transactions)
# 3. Go to Settings -> API Keys
# 4. Copy Test/Sandbox keys for development
# 5. Copy Live keys for production
# 6. Set up webhook URL in Settings -> Webhooks:
#    - Test: https://yourdomain.com/api/payments/webhook
#    - Live: https://yourdomain.com/api/payments/webhook
